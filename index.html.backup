        <section id="collections" class="collections reveal fade-bottom">
            <h2 class="reveal fade-bottom">Collections</h2>
            <div class="collection-grid" id="collection-grid">
                <!-- Collection cards will be loaded dynamically -->
                <div class="loading">Loading collections...</div>
            </div>
            
            <script>
            document.addEventListener('DOMContentLoaded', function() {
                // Define our collections
                const collections = [
                    { name: 'Watercolors', url: 'watercolors.html', imageKey: 'watercolors-card' },
                    { name: 'Black & Whites', url: 'black-and-whites.html', imageKey: 'black-and-whites-card' },
                    { name: 'Early Works', url: 'early-works.html', imageKey: 'early-works-card' },
                    { name: 'Large Works', url: 'large-works.html', imageKey: 'large-works-card' }
                ];
                
                // Get the collection grid element
                const grid = document.getElementById('collection-grid');
                
                // Load homepage images from the PHP API
                fetch('/DickWrayWebsite/api/list-images.php?collection=homepage')
                    .then(response => response.json())
                    .then(data => {
                        // Clear loading indicator
                        grid.innerHTML = '';
                        
                        if (data.error) {
                            console.error('Error loading homepage images:', data.error);
                            // Fallback to create the collection grid with default layout
                            createCollectionGrid(grid, collections, {});
                            return;
                        }
                        
                        // Create a map of image keys to image paths
                        const imageMap = {};
                        data.images.forEach(image => {
                            // Extract the image key from the filename (without extension)
                            const key = image.filename.split('.')[0];
                            imageMap[key] = image.path;
                        });
                        
                        // Create the collection grid with our image map
                        createCollectionGrid(grid, collections, imageMap);
                    })
                    .catch(error => {
                        console.error('Error loading homepage images:', error);
                        // Fallback to create the collection grid with default layout
                        grid.innerHTML = '';
                        createCollectionGrid(grid, collections, {});
                    });
                
                // Function to create the collection grid with available images
                function createCollectionGrid(grid, collections, imageMap) {
                    collections.forEach(collection => {
                        // Create the collection item
                        const item = document.createElement('a');
                        item.href = collection.url;
                        item.className = 'collection-item tilt';
                        
                        // Create the image element
                        const img = document.createElement('img');
                        // Use the image from our map if available, otherwise use a fallback
                        if (imageMap[collection.imageKey]) {
                            img.src = imageMap[collection.imageKey];
                        } else {
                            // Fallback to default paths if images aren't in our API response
                            const fallbackPaths = {
                                'watercolors-card': '/DickWrayWebsite/assets/images/collections/homepage/watercolors-card.jpg',
                                'black-and-whites-card': '/DickWrayWebsite/assets/images/collections/homepage/black-and-whites-card.jpg',
                                'early-works-card': '/DickWrayWebsite/assets/images/collections/homepage/early-works-card.jpg',
                                'large-works-card': '/DickWrayWebsite/assets/images/collections/homepage/large-works-card.jpg'
                            };
                            img.src = fallbackPaths[collection.imageKey];
                        }
                        img.alt = collection.name;
                        img.className = 'tilt-child';
                        
                        // Create the overlay with title
                        const overlay = document.createElement('div');
                        overlay.className = 'collection-overlay';
                        
                        const title = document.createElement('h3');
                        title.className = 'tilt-child';
                        title.textContent = collection.name;
                        
                        overlay.appendChild(title);
                        
                        // Add elements to the collection item
                        item.appendChild(img);
                        item.appendChild(overlay);
                        
                        // Add the collection item to the grid
                        grid.appendChild(item);
                    });
                    
                    // Re-initialize tilt effect if necessary
                    if (typeof initTilt === 'function') {
                        initTilt();
                    }
                }
            });
            </script>
        </section>

