[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/robertwrayscode/websites.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "master"]
	remote = origin
	merge = refs/heads/master
[branch "reorganize-structure"]
	vscode-merge-base = origin/master
	remote = origin
	merge = refs/heads/reorganize-structure
[branch "folder-structure"]
	vscode-merge-base = origin/reorganize-structure
