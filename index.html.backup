    <script>
        // Immediate theme toggle function
        function toggleTheme() {
            const root = document.documentElement;
            const themeIcon = document.querySelector('#theme-toggle i');
            const logoImages = document.querySelectorAll('#logo-image');
            const signatureImages = document.querySelectorAll('.signature-image');
            
            root.classList.toggle('light-theme');
            
            if (root.classList.contains('light-theme')) {
                // Switch to light theme
                themeIcon.className = 'fas fa-sun';
                localStorage.setItem('theme', 'light');
                // Change all logo images to inverted version
                logoImages.forEach(img => {
                    img.src = 'Dick%20Wray%20Images/dickwray-log_INVERTED.png';
                });
                // Change signature images to black version
                signatureImages.forEach(img => {
                    img.src = 'Dick%20Wray%20Images/Signature_black.png';
                });
            } else {
                // Switch to dark theme
                themeIcon.className = 'fas fa-moon';
                localStorage.setItem('theme', 'dark');
                // Change all logo images to white version
                logoImages.forEach(img => {
                    img.src = 'assets/images/branding/dickwray-logo_white.png';
                });
                // Change signature images to white version
                signatureImages.forEach(img => {
                    img.src = 'Dick%20Wray%20Images/Signature_white.png';
                });
            }
        }
        
        // Check for saved theme preference on page load
        document.addEventListener('DOMContentLoaded', function() {
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme === 'light') {
                document.documentElement.classList.add('light-theme');
                document.querySelector('#theme-toggle i').className = 'fas fa-sun';
                
                // Update logo images on initial load if light theme
                document.querySelectorAll('#logo-image').forEach(img => {
                    img.src = 'Dick%20Wray%20Images/dickwray-log_INVERTED.png';
                });
                
                // Update signature images on initial load if light theme
                document.querySelectorAll('.signature-image').forEach(img => {
                    img.src = 'Dick%20Wray%20Images/Signature_black.png';
                });
            }
        });
    </script>
